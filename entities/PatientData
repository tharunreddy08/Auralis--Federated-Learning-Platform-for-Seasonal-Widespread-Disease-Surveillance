{
  "name": "PatientData",
  "type": "object",
  "properties": {
    "hospital_id": {
      "type": "string",
      "title": "Hospital ID"
    },
    "hospital_name": {
      "type": "string",
      "title": "Hospital Name"
    },
    "disease": {
      "type": "string",
      "title": "Disease",
      "enum": [
        "influenza",
        "dengue",
        "malaria",
        "covid19",
        "cholera",
        "tuberculosis",
        "typhoid",
        "hepatitis"
      ]
    },
    "age": {
      "type": "number",
      "title": "Patient Age"
    },
    "gender": {
      "type": "string",
      "enum": [
        "male",
        "female",
        "other"
      ],
      "title": "Gender"
    },
    "symptoms": {
      "type": "string",
      "title": "Symptoms"
    },
    "severity": {
      "type": "string",
      "enum": [
        "mild",
        "moderate",
        "severe",
        "critical"
      ],
      "title": "Severity"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "recovered",
        "under_treatment",
        "deceased"
      ],
      "title": "Outcome"
    },
    "report_date": {
      "type": "string",
      "format": "date-time",
      "title": "Report Date"
    },
    "latitude": {
      "type": "number",
      "title": "Latitude"
    },
    "longitude": {
      "type": "number",
      "title": "Longitude"
    },
    "region": {
      "type": "string",
      "title": "Region"
    }
  },
  "required": [
    "hospital_name",
    "disease",
    "severity",
    "report_date"
  ]
}